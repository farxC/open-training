# Copy this file to .env.local (git-ignored) and fill in your real values.
# The Makefile loads .env.local automatically for `make android-release`.
# Generate the keystore first with:
#   keytool -genkeypair -v -storetype PKCS12 -keystore release.keystore \
#     -alias open-training-release -keyalg RSA -keysize 2048 -validity 10000
#
# IMPORTANT: no quotes around values. This file is included as Make syntax
# (not sourced as shell), so `FOO="bar"` sets FOO to the literal 5 characters
# "bar" including the quote marks — not what Gradle expects for a password.

# Path to your .keystore file. If relative, it resolves inside android/app/ —
# either move the keystore there or use an absolute path.
ANDROID_RELEASE_STORE_FILE=release.keystore

# The password you set with -storepass (or typed interactively) when running keytool.
ANDROID_RELEASE_STORE_PASSWORD=

# The alias you passed to -alias when running keytool.
ANDROID_RELEASE_KEY_ALIAS=open-training-release

# The password you set with -keypass (often the same as the store password).
ANDROID_RELEASE_KEY_PASSWORD=

# Optional: pin the JDK used for Gradle builds. This project's Android Gradle
# Plugin/RN combo isn't compatible with very new JDKs (e.g. 21+) — install
# Temurin 17 (`brew install --cask temurin@17`) and point this at it instead
# of changing your system-wide default JDK. Find the path with:
#   /usr/libexec/java_home -v 17
JAVA_HOME=

# Optional: Android SDK location, if not already exported globally.
# Install with `brew install --cask android-commandlinetools` (no sudo
# needed), then accept licenses and install the platform/build-tools it asks
# for (see .github/workflows/android-build.yml for the exact sdkmanager
# invocation). Default install path for that cask:
ANDROID_HOME=/opt/homebrew/share/android-commandlinetools
