{
  "expo": {
    "name": "open-training",
    "slug": "open-training",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "open-training",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opentraining.app"
    },
    "android": {
      "package": "com.opentraining.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to attach to workout sessions."
        }
      ],
      "./plugins/withAndroidReleaseSigning"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
